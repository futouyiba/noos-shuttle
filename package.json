{
  "name": "noos-shuttle",
  "version": "0.1.4",
  "private": true,
  "description": "NOOS Shuttle packages AI conversations into agent-ready handoff threads.",
  "author": "FuTou 2026",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "package:extension": "node scripts/package-extension.mjs",
    "package:release": "node scripts/package-release-artifacts.mjs",
    "sleep:acceptance": "scripts/noos-sleep-resume-acceptance.sh",
    "sleep:acceptance:self-test": "scripts/noos-sleep-resume-acceptance-self-test.sh",
    "sleep:audit": "scripts/noos-sleep-resume-audit.sh",
    "sleep:audit:self-test": "scripts/noos-sleep-resume-audit-self-test.sh",
    "sleep:guided": "scripts/noos-sleep-resume-guided-test.sh",
    "sleep:guided:self-test": "scripts/noos-sleep-resume-guided-self-test.sh",
    "sleep:preflight": "scripts/noos-sleep-resume-preflight.sh",
    "sleep:preflight:self-test": "scripts/noos-sleep-resume-preflight-self-test.sh",
    "sleep:readiness": "scripts/noos-sleep-resume-readiness.sh",
    "sleep:readiness:self-test": "scripts/noos-sleep-resume-readiness-self-test.sh",
    "sleep:recovery:test": "npm run hub:sleep-recovery:test && npm run wiki:sleep-recovery:test",
    "sleep:self-test": "scripts/noos-sleep-resume-self-test.sh",
    "sleep:status": "scripts/noos-sleep-resume-status.sh",
    "sleep:status:self-test": "scripts/noos-sleep-resume-status-self-test.sh",
    "verify:extension-project": "node scripts/verify-extension-project-import.mjs",
    "hub:dev": "npm --prefix apps/noos-hub run tauri:dev",
    "hub:build": "npm run hub:web:build && cargo build --manifest-path apps/noos-hub/src-tauri/Cargo.toml",
    "hub:bundle": "node scripts/noos-hub-bundle.mjs",
    "hub:launch": "scripts/noos-hub-launch.sh start",
    "hub:logs": "scripts/noos-hub-launch.sh logs",
    "hub:post-wake-check": "scripts/noos-post-wake-check.sh",
    "hub:post-wake-check:self-test": "scripts/noos-post-wake-check-self-test.sh",
    "hub:prepare-extension": "node scripts/noos-prepare-hub-extension.mjs",
    "hub:sleep-recovery:test": "cargo test --manifest-path apps/noos-hub/src-tauri/Cargo.toml sleep_recovery",
    "hub:run": "npm run hub:web:build && cargo run --manifest-path apps/noos-hub/src-tauri/Cargo.toml",
    "hub:status": "scripts/noos-hub-launch.sh status",
    "hub:stop": "scripts/noos-hub-launch.sh stop",
    "hub:web:build": "npm --prefix apps/noos-hub run build",
    "wiki:build": "npm --prefix apps/llm-wiki run build",
    "wiki:dev": "npm --prefix apps/llm-wiki run tauri dev",
    "wiki:launch": "scripts/llm-wiki-launch.sh start",
    "wiki:logs": "scripts/llm-wiki-launch.sh logs",
    "wiki:post-wake-check": "scripts/llm-wiki-post-wake-check.sh",
    "wiki:post-wake-check:self-test": "scripts/llm-wiki-post-wake-check-self-test.sh",
    "wiki:sleep-recovery:test": "cargo test --manifest-path apps/llm-wiki/src-tauri/Cargo.toml sleep_recovery",
    "wiki:status": "scripts/llm-wiki-launch.sh status",
    "wiki:stop": "scripts/llm-wiki-launch.sh stop",
    "wiki:test": "npm --prefix apps/llm-wiki run test:mocks",
    "wiki:typecheck": "npm --prefix apps/llm-wiki run typecheck",
    "wiki:vendor-check": "scripts/noos-wiki-vendor-check.sh",
    "wiki:vendor-check:self-test": "scripts/noos-wiki-vendor-check-self-test.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "sleep:arm": "scripts/noos-sleep-resume-arm.sh start",
    "sleep:arm:status": "scripts/noos-sleep-resume-arm.sh status",
    "sleep:arm:stop": "scripts/noos-sleep-resume-arm.sh stop",
    "sleep:arm:logs": "scripts/noos-sleep-resume-arm.sh logs",
    "sleep:arm:self-test": "scripts/noos-sleep-resume-arm-self-test.sh"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
