{
  "manifest_version": 3,
  "name": "NOOS Shuttle",
  "description": "Package ChatGPT conversations into agent-ready NOOS Thread handoffs.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["clipboardWrite", "downloads"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chat.deepseek.com/*",
    "https://kimi.moonshot.cn/*",
    "https://yuanbao.tencent.com/*",
    "https://www.doubao.com/*",
    "https://chat.qwen.ai/*",
    "https://grok.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*"
  ],
  "background": {
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://yuanbao.tencent.com/*",
        "https://www.doubao.com/*",
        "https://chat.qwen.ai/*",
        "https://grok.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
