{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NOOS Hub",
  "version": "0.1.4",
  "identifier": "app.noos.shuttle.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build && npm --prefix ../.. run hub:prepare-extension",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NOOS Hub",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources/noos-shuttle-extension"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEQTdGQzk0MjI2MkRCMDQKUldRRTIySWlsUHluN2FXUXJVRUh1VEwwOUorc1dNK2JURDAwQmcyWEtHNXNHZC9jOGRJZlNtQmEK",
      "endpoints": [
        "https://github.com/futouyiba/noos-shuttle/releases/latest/download/noos-hub-latest.json"
      ]
    }
  }
}
